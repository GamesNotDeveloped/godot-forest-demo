[application]

config/name="Forest Test Scene"
run/main_scene="uid://dwmdxxavjugan"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://icon.svg"

[audio]

buses/default_bus_layout="uid://dv4nk0yideb2f"

[autoload]

DebugMenu="*uid://cggqb75a8w8r"

[editor_plugins]

enabled=PackedStringArray("res://addons/debug_menu/plugin.cfg", "res://addons/gnd_biomes/plugin.cfg", "res://addons/gnd_skydome/plugin.cfg", "res://addons/gnd_weather/plugin.cfg", "res://addons/uniplayer/plugin.cfg")

[layer_names]

3d_render/layer_17="SimpleGrassTextured interactive layer"

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

